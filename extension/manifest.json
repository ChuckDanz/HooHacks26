{
  "manifest_version": 3,
  "name": "FitCheck – Virtual Try-On",
  "version": "1.0.0",
  "description": "Capture cart items from Amazon, H&M, Depop and Shein for AI virtual try-on.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://www.hm.com/*",
    "https://www2.hm.com/*",
    "https://www.depop.com/*",
    "https://us.shein.com/*",
    "https://www.shein.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://www.hm.com/*",
        "https://www2.hm.com/*",
        "https://www.depop.com/*",
        "https://us.shein.com/*",
        "https://www.shein.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "FitCheck",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
